# ─── Online Lab — environment variables ─────────────────────────────────────
# Copy to .env for local dev of the online server (npm run dev:online).
# In production these are set in the Render dashboard, NOT in a .env file.
# Never commit a real .env.

# Supabase — from Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini — Phase 1 platform key. Phase 2 will swap to per-user BYOK.
GEMINI_API_KEY=

# Server (Render injects PORT automatically; HOST should stay 0.0.0.0)
PORT=8080
HOST=0.0.0.0

# Result retention. Default 3 days.
SCENE_TTL_MS=259200000

# Point-cloud grid resolution (long-axis pixels).
#   200 = ~40k points, ~10–20 KB JSON per scene.
#   600 = ~360k points, ~350 KB – 1 MB JSON per scene.
#   800 = ~640k points, ~600 KB – 2 MB JSON per scene.
GRID_SIZE=600

# Comma-separated list of allowed origins. Empty = same-origin only.
# Example: ALLOWED_ORIGINS=https://lab.yourdomain.com,https://nona-portfolio-eight.vercel.app
ALLOWED_ORIGINS=
